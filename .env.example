# H4wkQuant Environment Configuration

# Binance Futures API
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_FUTURES_TESTNET=false

# Database
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5434
DB_POSTGRES_USER=h4wk
DB_POSTGRES_PASSWORD=changeme
DB_POSTGRES_DB=h4wk_quant

# Redis (DB 1 for H4wkQuant)
REDIS_URL=redis://localhost:6379/1

# Trading Mode: paper or live
TRADING_MODE=paper

# Panel
PANEL_SECRET_KEY=change_this_to_random_string

# Telegram Notifications (optional)
MONITOR_TELEGRAM_ENABLED=false
MONITOR_TELEGRAM_BOT_TOKEN=
MONITOR_TELEGRAM_CHAT_ID=

